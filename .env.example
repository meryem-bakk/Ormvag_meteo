# Copiez ce fichier en ".env" et remplissez avec vos vraies valeurs.
# Ne jamais committer le fichier ".env" (déjà exclu via .gitignore).

# Chaîne de connexion PostgreSQL
# Format : postgresql://utilisateur:mot_de_passe@hote:port/nom_base
DATABASE_URL=postgresql://utilisateur:mot_de_passe@localhost:5432/ormvag_meteo

# Mot de passe utilisé par seed_admin.py pour créer le compte admin initial.
# Optionnel : si non défini, un mot de passe aléatoire est généré et affiché une seule fois.
ADMIN_SEED_PASSWORD=admin123

# Envoi automatique par email du rapport journalier (tâche planifiée à 8h00).
# Exemple Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=votre adresse,
# SMTP_PASSWORD = un "mot de passe d'application" Gmail (pas le mot de passe du compte).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_adresse@gmail.com
SMTP_PASSWORD=mot_de_passe_application
# Plusieurs adresses séparées par des virgules
SMTP_DESTINATAIRES=destinataire1@example.com,destinataire2@example.com

# Chemin vers pg_dump.exe, utilisé pour la sauvegarde de la base (manuelle et
# automatique à 8h00). Optionnel : si absent, recherché automatiquement dans
# C:\Program Files\PostgreSQL\<version>\bin\ (Windows).
# PG_DUMP_PATH=C:\Program Files\PostgreSQL\18\bin\pg_dump.exe
